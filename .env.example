# ── Bot ───────────────────────────────────────────────────────────────────────
BOT_TOKEN=
WEBHOOK_SECRET=

# Private network URL of the @orbit/api service.
# Local dev: http://localhost:8080
# Railway:   http://api.railway.internal:8080
API_BASE_URL=

# Shared Bearer secret (must match API_BOT_TOKEN in the api service).
# Use `openssl rand -hex 32` to generate.
API_BOT_TOKEN=

PORT=3000
NODE_ENV=development

# ── API ───────────────────────────────────────────────────────────────────────
# DATABASE_URL is required by @orbit/api only. Do NOT set it on the bot service.
DATABASE_URL=

PORT=8080
NODE_ENV=development
LOG_LEVEL=info
