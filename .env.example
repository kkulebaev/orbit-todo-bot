# ── Bot — Telegram ────────────────────────────────────────────────────────────
BOT_TOKEN=
WEBHOOK_SECRET=

# ── Bot — DB (P0–P4 only; remove after P5 cutover) ───────────────────────────
DATABASE_URL=

# ── Bot — API client (new in P2) ──────────────────────────────────────────────
# Private network URL of the @orbit/api service.
# Local dev: http://localhost:8080
# Railway:   http://api.railway.internal:8080
API_BASE_URL=

# Shared Bearer secret (must match API_BOT_TOKEN in the api service).
API_BOT_TOKEN=

# P2 schema-canary: set true to enable parallel API reads (fire-and-forget).
# User always receives the Prisma result; API response is only Zod-validated.
SHADOW_MODE=false

# P3: route bot READs (task list + task detail) through @orbit/api.
# When true + SHADOW_MODE=false, API is the live source of truth for reads.
# On API failure, bot falls back to Prisma (graceful degradation).
# Write operations and PendingAction remain Prisma-backed until P4.
READ_FROM_API=false

# P4: route bot WRITEs and PendingAction (sessions) through @orbit/api.
# Requires READ_FROM_API=true and a stable P3 baseline before flipping.
# On API failure the bot DOES NOT fall back to Prisma — the user sees
# "🛠 Сервис временно недоступен" and the operation is NOT committed anywhere.
# This is the migration commit point. Roll back by setting WRITE_VIA_API=false
# and redeploying. See docs/railway-deploy.md "P4 cutover".
WRITE_VIA_API=false

# ── API ───────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
LOG_LEVEL=info
