# ── Bot ───────────────────────────────────────────────────────────────────────
BOT_TOKEN=
WEBHOOK_SECRET=

# Private network URL of the @orbit/api service.
# Local dev: http://localhost:8080
# Railway:   http://api.railway.internal:8080
API_BASE_URL=

# Bot's Personal Access Token plaintext (used by the bot to authenticate to
# @orbit/api). The corresponding SHA-256 hash is seeded into the api service
# as `BOT_PAT_SHA256` (see below). Plaintext MUST match
# /^orbit_pat_[A-Za-z0-9_-]{43,}$/ (AC-P2-12).
BOT_PAT=

PORT=3000
NODE_ENV=development

# ── API ───────────────────────────────────────────────────────────────────────
# DATABASE_URL is required by @orbit/api only. Do NOT set it on the bot service.
DATABASE_URL=

PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# PAT seed for the bot's system account.
# Set on the api service. Operator picks a fixed UUID for BOT_PAT_USER_ID once
# and reuses it across redeploys. BOT_PAT_SHA256 is the lowercase hex SHA-256
# of the bot's chosen BOT_PAT plaintext.
BOT_PAT_USER_ID=
BOT_PAT_SHA256=

# Comma-separated CIDR list allowed for canImpersonate=true PATs (bot PAT).
# Railway internal IPv6 range + loopback addresses for local-dev/health-checks.
BOT_PAT_ALLOWED_CIDR=fd00::/8,::1,127.0.0.1/32

# ── Bootstrap ─────────────────────────────────────────────────────────────────
# One-time bot PAT bootstrap procedure (Architect iter-3 M4 option (b)):
#
#   1. Generate a strong plaintext (matches AC-P2-12 regex):
#        BOT_PAT=orbit_pat_$(openssl rand -base64 32 | tr -d '=' | tr '/+' '_-')
#
#   2. Compute its SHA-256 hex:
#        BOT_PAT_SHA256=$(node -e \
#          "console.log(require('crypto').createHash('sha256').update(process.argv[1]).digest('hex'))" \
#          "$BOT_PAT")
#
#   3. Pick a fixed UUID once and reuse on every redeploy:
#        BOT_PAT_USER_ID=$(node -e "console.log(require('crypto').randomUUID())")
#
#   4. Set BOT_PAT on the bot service. Set BOT_PAT_USER_ID + BOT_PAT_SHA256 on
#      the api service. Run `prisma db seed` (already wired into the deploy
#      pipeline) — the row is upserted idempotently.
