{
  "name": "@orbit/bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx --env-file-if-exists=.env src/bot.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file-if-exists=.env dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --max-warnings=999"
  },
  "dependencies": {
    "@orbit/contracts": "workspace:*",
    "@prisma/client": "^6.19.1",
    "express": "^5.2.1",
    "grammy": "^1.41.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2"
  }
}
